<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Painel Gamer Pro</title>

<style>
body{
    margin:0;
    background:#0a0a0a;
    color:#fff;
    font-family:Arial,sans-serif;
}

.container{
    max-width:500px;
    margin:20px auto;
    padding:15px;
}

h1{
    text-align:center;
    color:#00ff66;
}

.card{
    background:#1a1a1a;
    border-radius:15px;
    padding:20px;
    margin-bottom:15px;
    box-shadow:0 0 15px rgba(0,255,102,.25);
}

.titulo{
    color:#aaa;
    margin-bottom:8px;
    font-size:14px;
}

.valor{
    font-size:28px;
    font-weight:bold;
    color:#00ff66;
}

select{
    width:100%;
    padding:12px;
    border:none;
    border-radius:10px;
    background:#222;
    color:white;
    font-size:16px;
}

button{
    width:100%;
    padding:15px;
    border:none;
    border-radius:10px;
    background:#00ff66;
    color:black;
    font-size:18px;
    font-weight:bold;
    cursor:pointer;
}
</style>
</head>
<body>

<div class="container">

<h1>⚡ PAINEL GAMER PRO</h1>

<div class="card">
    <div class="titulo">Configuração de FPS</div>
    <select id="fps" onchange="atualizar()">
        <option value="60">60 FPS</option>
        <option value="120" selected>120 FPS</option>
    </select>
</div>

<div class="card">
    <div class="titulo">Configuração de RAM</div>
    <select id="ram" onchange="atualizar()">
        <option value="3">3 GB RAM</option>
        <option value="6" selected>6 GB RAM</option>
    </select>
</div>

<div class="card">
    <div class="titulo">FPS Atual</div>
    <div class="valor" id="fpsValor">120 FPS</div>
</div>

<div class="card">
    <div class="titulo">RAM Atual</div>
    <div class="valor" id="ramValor">6 GB</div>
</div>

<div class="card">
    <div class="titulo">CPU</div>
    <div class="valor">28%</div>
</div>

<div class="card">
    <div class="titulo">Temperatura</div>
    <div class="valor">37°C</div>
</div>

<div class="card">
    <div class="titulo">Ping</div>
    <div class="valor">18 ms</div>
</div>

<div class="card">
    <div class="titulo">Armazenamento Livre</div>
    <div class="valor">64 GB</div>
</div>

<div class="card">
    <div class="titulo">Modo Gamer</div>
    <div class="valor">ATIVO</div>
</div>

<div class="card">
    <div class="titulo">Status</div>
    <div class="valor">OTIMIZADO</div>
</div>

<div class="card">
    <button onclick="otimizar()">
        🚀 EXECUTAR BOOST
    </button>
</div>

</div>

<script>
function atualizar(){
    let fps = document.getElementById("fps").value;
    let ram = document.getElementById("ram").value;

    document.getElementById("fpsValor").innerHTML = fps + " FPS";
    document.getElementById("ramValor").innerHTML = ram + " GB";
}

function otimizar(){
    atualizar();

    alert(
        "✓ Configuração aplicada\n" +
        "✓ FPS: " + document.getElementById("fps").value + "\n" +
        "✓ RAM: " + document.getElementById("ram").value + " GB\n" +
        "✓ Modo Gamer ativado\n" +
        "✓ Sistema pronto"
    );
}
</script>

</body>
</html>
